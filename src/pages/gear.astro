---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gear and accessories">
  <section class="page-section hero">
    <p class="eyebrow">Gear</p>
    <h1>Hardware, accessories, and interfaces for immersive experiences.</h1>
    <p class="lead">
      A place to organize headsets, glasses, controllers, haptics, sensors,
      displays, and development platforms.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section grid">
      <article class="card">
        <h3>Headsets and glasses</h3>
        <p>Comparisons, device families, and the tradeoffs behind each form factor.</p>
      </article>
      <article class="card">
        <h3>Haptics</h3>
        <p>Gloves, vests, tactile feedback, and other ways of feeling interfaces.</p>
      </article>
      <article class="card">
        <h3>Tracking and sensors</h3>
        <p>How systems perceive bodies, hands, eyes, spaces, and objects.</p>
      </article>
    </div>
  </section>
</BaseLayout>
