---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="About the author">
  <section class="page-section hero">
    <p class="eyebrow">About the author</p>
    <h1>A short author note is in development.</h1>
    <p class="lead">
      Augmented Notes is maintained by {site.author}. This discreet section will
      soon describe the author's experience in the immersive technology market.
    </p>
    <div class="hero-actions">
      <a class="button" href={site.linkedin}>LinkedIn</a>
      <a class="button secondary" href="/">Back to home</a>
    </div>
  </section>
</BaseLayout>
