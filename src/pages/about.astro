---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="About the author">
  <section class="page-section hero">
    <p class="eyebrow">About the author</p>
    <h1>A public notebook on immersive technologies.</h1>
    <p class="lead">
      Augmented Notes is maintained by {site.author}, a professional with
      experience in the immersive technology market. This space exists to
      organize, translate, and share knowledge about AR, VR, MR, and XR.
    </p>
    <div class="hero-actions">
      <a class="button" href={site.linkedin}>LinkedIn</a>
      <a class="button secondary" href="/blog/">Read articles</a>
    </div>
  </section>
</BaseLayout>
