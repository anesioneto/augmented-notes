---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Equipamentos e acessorios">
  <section class="page-section hero">
    <p class="eyebrow">Equipamentos</p>
    <h1>Hardware, acessorios e interfaces para experiencias imersivas.</h1>
    <p class="lead">
      Uma area para organizar headsets, oculos, controladores, haptics,
      sensores, displays e plataformas de desenvolvimento.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section grid">
      <article class="card">
        <h3>Headsets e oculos</h3>
        <p>Comparacoes, caracteristicas e familias de dispositivos.</p>
      </article>
      <article class="card">
        <h3>Haptics</h3>
        <p>Luvas, coletes, feedback tactil e outras formas de sentir interfaces.</p>
      </article>
      <article class="card">
        <h3>Tracking e sensores</h3>
        <p>Como os sistemas percebem corpo, maos, olhos, espaco e objetos.</p>
      </article>
    </div>
  </section>
</BaseLayout>
