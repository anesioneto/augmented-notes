---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Casos de uso">
  <section class="page-section hero">
    <p class="eyebrow">Casos de uso</p>
    <h1>Onde AR, VR e MR criam valor no mundo real.</h1>
    <p class="lead">
      Exemplos e referencias para entender como tecnologias imersivas aparecem
      em educacao, saude, industria, cultura, treino, turismo, retalho e trabalho.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section grid">
      <article class="card">
        <h3>Educacao e treino</h3>
        <p>Simulacoes, aprendizagem experiencial e pratica em ambientes seguros.</p>
      </article>
      <article class="card">
        <h3>Industria e operacoes</h3>
        <p>Assistencia remota, manutencao, design review e visualizacao tecnica.</p>
      </article>
      <article class="card">
        <h3>Cultura e entretenimento</h3>
        <p>Experiencias narrativas, museus, arte, eventos e media imersivos.</p>
      </article>
    </div>
  </section>
</BaseLayout>
