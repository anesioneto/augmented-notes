---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Use cases">
  <section class="page-section hero">
    <p class="eyebrow">Use cases</p>
    <h1>Where AR, VR, and MR create value in the real world.</h1>
    <p class="lead">
      Examples and references for understanding how immersive technologies show
      up in education, healthcare, industry, culture, training, tourism, retail,
      and work.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section grid">
      <article class="card">
        <h3>Education and training</h3>
        <p>Simulations, experiential learning, and practice in controlled environments.</p>
      </article>
      <article class="card">
        <h3>Industry and operations</h3>
        <p>Remote assistance, maintenance, design review, and technical visualization.</p>
      </article>
      <article class="card">
        <h3>Culture and entertainment</h3>
        <p>Narrative experiences, museums, art, events, and immersive media.</p>
      </article>
    </div>
  </section>
</BaseLayout>
