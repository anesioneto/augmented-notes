---
import BaseLayout from "../layouts/BaseLayout.astro";
import { newsSources } from "../data/newsSources";
---

<BaseLayout title="Radar XR">
  <section class="page-section hero">
    <p class="eyebrow">Radar XR</p>
    <h1>The XR news radar is being prepared.</h1>
    <p class="lead">
      This section will gather recent links from selected XR sources. The first
      version will work as a curated index before the automated RSS layer is
      added. Please return soon.
    </p>
    <div class="hero-actions">
      <a class="button" href="/">Back to home</a>
      <a class="button secondary" href="/coming-soon/">Content status</a>
    </div>
  </section>

  <section class="section-band">
    <div class="page-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Sources</p>
          <h2>Initial source list</h2>
        </div>
      </div>
      <div class="source-grid">
        {
          newsSources.map((source) => (
            <a class="source-item" href="/coming-soon/">
              <strong>{source.name}</strong>
              <span class="small">{source.category}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
