---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postPath = (id: string) => id.replace(/\.mdx?$/, "");
---

<BaseLayout title="Blog" description="Artigos do Augmented Notes">
  <section class="page-section hero">
    <p class="eyebrow">Blog</p>
    <h1>Notas publicadas</h1>
    <p class="lead">
      Artigos e guias para construir uma compreensao progressiva do universo XR.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section post-list">
      {
        posts.map((post) => (
          <a class="post-row" href={`/blog/${postPath(post.id)}/`}>
            <span class="post-meta">{post.data.category}</span>
            <span>
              <strong>{post.data.title}</strong>
              <br />
              <span class="small">{post.data.description}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
