---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { radarItems } from "../data/radarItems";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const postPath = (id: string) => id.replace(/\.mdx?$/, "");
---

<BaseLayout>
  <section class="page-section hero">
    <p class="eyebrow">AR / VR / MR / XR</p>
    <h1>Notes for understanding the immersive present.</h1>
    <p class="lead">
      Guides, references, and curated signals on immersive technologies, from
      core concepts to devices, accessories, and real-world use cases.
    </p>
    <div class="hero-actions">
      <a class="button" href="/fundamentals/">Explore fundamentals</a>
      <a class="button secondary" href="/radar/">Open Radar XR</a>
    </div>
  </section>

  <section class="section-band">
    <div class="page-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Site map</p>
          <h2>A living reference for XR</h2>
        </div>
        <p>
          The site combines evergreen explanations with a faster news layer for
          following the ecosystem as it evolves.
        </p>
      </div>
      <div class="grid">
        <a class="card" href="/fundamentals/">
          <h3>XR fundamentals</h3>
          <p>Essential concepts around AR, VR, MR, spatial computing, tracking, and presence.</p>
        </a>
        <a class="card" href="/gear/">
          <h3>Gear and accessories</h3>
          <p>Headsets, controllers, haptics, sensors, displays, and platforms.</p>
        </a>
        <a class="card" href="/use-cases/">
          <h3>Use cases</h3>
          <p>Applications in education, healthcare, industry, culture, retail, and collaboration.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="page-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Articles</p>
          <h2>First notes</h2>
        </div>
        <a href="/blog/">View all</a>
      </div>
      <div class="post-list">
        {
          posts.map((post) => (
            <a class="post-row" href={`/blog/${postPath(post.id)}/`}>
              <span class="post-meta">{post.data.category}</span>
              <span>
                <strong>{post.data.title}</strong>
                <br />
                <span class="small">{post.data.description}</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="page-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Radar XR</p>
          <h2>News and references</h2>
        </div>
        <a href="/radar/">Open radar</a>
      </div>
      {
        radarItems.map((item) => (
          <a class="news-row" href={item.url}>
            <span class="post-meta">{item.source}</span>
            <span>
              <strong>{item.title}</strong>
              <br />
              <span class="small">{item.summary}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
