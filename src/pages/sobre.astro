---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Nota do autor">
  <section class="page-section hero">
    <p class="eyebrow">Nota do autor</p>
    <h1>Um caderno publico sobre tecnologias imersivas.</h1>
    <p class="lead">
      O Augmented Notes e mantido por {site.author}, profissional com experiencia
      no mercado imersivo. Este espaco nasce da vontade de organizar, traduzir e
      partilhar conhecimento sobre AR, VR, MR e XR.
    </p>
    <div class="hero-actions">
      <a class="button" href={site.linkedin}>LinkedIn</a>
      <a class="button secondary" href="/blog/">Ler artigos</a>
    </div>
  </section>
</BaseLayout>
