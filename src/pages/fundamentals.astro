---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((post) => post.data.category === "Fundamentals" && !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postPath = (id: string) => id.replace(/\.mdx?$/, "");
---

<BaseLayout title="XR Fundamentals">
  <section class="page-section hero">
    <p class="eyebrow">Fundamentals</p>
    <h1>The essential vocabulary of immersive technologies.</h1>
    <p class="lead">
      Clear explanations of AR, VR, MR, XR, presence, interaction, tracking,
      passthrough, spatial computing, and other core concepts.
    </p>
  </section>
  <section class="section-band">
    <div class="page-section post-list">
      {posts.map((post) => <a class="post-row" href={`/blog/${postPath(post.id)}/`}><span class="post-meta">{post.data.category}</span><span><strong>{post.data.title}</strong><br /><span class="small">{post.data.description}</span></span></a>)}
    </div>
  </section>
</BaseLayout>
